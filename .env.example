# -------------------------
# Docker Compose (local)
# -------------------------
POSTGRES_DB=tripflow
POSTGRES_USER=tripflow
POSTGRES_PASSWORD=tripflow_dev_password
POSTGRES_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@tripflow.local
PGADMIN_DEFAULT_PASSWORD=admin_dev_password
PGADMIN_PORT=5050

# -------------------------
# API (local suggestions)
# -------------------------
API_HTTP_PORT=5080
API_HTTPS_PORT=7080

# JWT için runtime API anahtarı (prod'da asla repo'ya koyma; user-secrets/SSM kullan)
JWT_ISSUER=tripflow
JWT_AUDIENCE=tripflow-web
JWT_SECRET=change_me_to_a_long_random_secret

# PostgreSQL connection string (lokalde compose ile)
# Not: API içinde bunu kullanacaksak, .NET'te env'den okuyacağız
CONNECTION_STRING=Host=localhost;Port=5432;Database=tripflow;Username=tripflow;Password=tripflow_dev_password

# Public base URL used in QR codes and badge PDFs.
# Set this in production (e.g. https://api.tripflow.io).
# In development the API falls back to the request host, so this can be left unset locally.
APP_PUBLIC_BASE_URL=http://localhost:5080

# Trusted reverse proxy IPs/networks for X-Forwarded-* header processing.
# Leave empty in development. In production set to your proxy's IP or CIDR range.
# Example (Render internal network): ReverseProxy__KnownNetworks=10.0.0.0/8
ReverseProxy__KnownProxies=
ReverseProxy__KnownNetworks=

# CORS: comma-separated list of allowed origins for the API (required in production).
# Example: CORS_ALLOWED_ORIGINS=https://app.tripflow.io,https://admin.tripflow.io
# CORS_ALLOWED_ORIGINS=

# -------------------------
# Web (local suggestions)
# -------------------------
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:5080
